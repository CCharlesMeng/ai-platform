{
  "name": "ai-platform",
  "version": "1.0.0",
  "private": true,
  "description": "AI 辅助研发学习与宣传阵地平台",
  "scripts": {
    "dev:portal": "npm run dev --workspace=packages/portal",
    "dev:admin": "npm run dev --workspace=packages/admin",
    "dev:backend": "npm run dev --workspace=packages/backend",
    "build:portal": "npm run build --workspace=packages/portal",
    "build:admin": "npm run build --workspace=packages/admin",
